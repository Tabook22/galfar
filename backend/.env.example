# Application
APP_NAME=Galfar Financial Reports
DEBUG=true

# Database (SQLite by default)
DATABASE_URL=sqlite:///./storage/galfar.db

# File storage
UPLOAD_DIR=./uploads
SAVED_ANALYSES_DIR=./storage/reports_analyzes

# LLM provider (placeholder — connect when ready)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_ENABLED=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
